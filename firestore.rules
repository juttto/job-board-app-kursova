rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function userData(uid) {
      return get(/databases/$(database)/documents/users/$(uid)).data;
    }

    function roleIs(role) {
      // Якщо документа користувача ще немає — роль не визначена, доступ забороняємо.
      return isSignedIn()
        && exists(/databases/$(database)/documents/users/$(request.auth.uid))
        && userData(request.auth.uid).role == role;
    }

    function isEmployer() {
      return roleIs("employer");
    }

    function isCandidate() {
      return roleIs("candidate");
    }

    match /users/{uid} {
      allow read: if isSignedIn() && request.auth.uid == uid;
      allow create: if isSignedIn()
        && request.auth.uid == uid
        && request.resource.data.uid == uid;
      // Забороняємо ескалацію ролі (candidate -> employer) через клієнтський update.
      allow update: if isSignedIn()
        && request.auth.uid == uid
        // Дозволяємо виправити legacy-документи без uid, але після цього uid має бути зафіксований.
        && request.resource.data.uid == uid
        // Якщо роль вже існує — забороняємо її змінювати.
        && (
          !("role" in resource.data)
          || request.resource.data.role == resource.data.role
        );
      allow delete: if false;
    }

    match /jobs/{jobId} {
      allow read: if true;

      allow create: if isEmployer()
        && request.resource.data.employerId == request.auth.uid;

      allow update, delete: if isEmployer()
        && resource.data.employerId == request.auth.uid;
    }

    match /resumes/{uid} {
      allow create, update: if isCandidate() && request.auth.uid == uid;
      allow read: if isEmployer() || (isSignedIn() && request.auth.uid == uid);
      allow delete: if isCandidate() && request.auth.uid == uid;
    }

    match /applications/{appId} {
      // Для стабільності дозволяємо відгук будь-якому авторизованому користувачу від свого UID.
      // UI додатково блокує роботодавця.
      allow create: if isSignedIn()
        && request.resource.data.candidateId == request.auth.uid;

      allow read: if isSignedIn()
        && resource.data.candidateId == request.auth.uid;

      allow read: if isEmployer()
        && get(/databases/$(database)/documents/jobs/$(resource.data.jobId)).data.employerId == request.auth.uid;

      // Роботодавець може змінювати статус відгуку лише на свої вакансії.
      allow update: if isEmployer()
        && get(/databases/$(database)/documents/jobs/$(resource.data.jobId)).data.employerId == request.auth.uid
        && request.resource.data.jobId == resource.data.jobId
        && request.resource.data.candidateId == resource.data.candidateId;

      allow delete: if false;
    }
  }
}
